# Copy this file to `.env` (cp .env.example .env)
# All values below are required - there are no defaults in application code.

# App
APP_NAME=QuoteFlow API
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true

# Database - PostgreSQL via asyncpg. Start it with `docker compose up db`.
DATABASE_URL=postgresql+asyncpg://quoteflow:quoteflow@localhost:5432/quoteflow

# Auth
SECRET_KEY=dev_secret_key_change_in_production_min_32_chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=720

# CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Currency (ISO 4217 code)
CURRENCY_CODE=USD

# AI provider (OpenAI-compatible chat completions; Groq shown as example).
# Leave AI_API_KEY empty to use the built-in offline heuristic draft (no external call).
AI_API_KEY=
AI_BASE_URL=https://api.groq.com/openai/v1
AI_MODEL=llama-3.1-8b-instant
AI_TIMEOUT_SECONDS=30

# n8n webhook called when a quotation is Approved (leave URL empty to disable)
N8N_WEBHOOK_URL=
N8N_TIMEOUT_SECONDS=10
