# QuoteFlow - copy to .env and adjust as needed

# Postgres
POSTGRES_USER=quoteflow
POSTGRES_PASSWORD=quoteflow
POSTGRES_DB=quoteflow
POSTGRES_PORT=5432

# App ports
API_PORT=8000
WEB_PORT=3000

# API
SECRET_KEY=dev_secret_key_change_in_production_min_32_chars
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CURRENCY_CODE=USD

# AI (optional - offline fallback when empty)
AI_API_KEY=
AI_BASE_URL=https://api.groq.com/openai/v1
AI_MODEL=llama-3.1-8b-instant

# n8n webhook (defaults work with docker compose stack)
N8N_WEBHOOK_URL=http://n8n:5678/webhook/quotation-approved
N8N_TIMEOUT_SECONDS=10

# n8n UI (host browser access)
N8N_HOST=localhost
N8N_PORT=5678
N8N_ENCRYPTION_KEY=quoteflow_n8n_dev_key_32chars!!

# Mailpit (local SMTP catcher)
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025

# Web
NEXT_PUBLIC_API_URL=http://localhost:8000
